datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Trabalhador {
  id                String   @id @default(uuid())
  email             String   @unique
  senhaLogin        String   // para o login (rf01 e rf02)
  senhaPublica      String?  // para o socorrista (rf04 e rf07)
  
  // campos clinicos (rf03)
  nome              String?
  sobrenome         String?
  sexo              String?
  tipoSanguineo     String?
  contatoEmergencia String?
  alergias          String?
  medicamentos      String?
  doencas           String?
  cirurgias         String?

}